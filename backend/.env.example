DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
PORT=3001

# 公网可达的后端根地址（云部署填 Railway 域名，如 https://xxx.up.railway.app）
PUBLIC_BASE_URL=

# 生产数据目录（Docker/Railway 默认 /data，本地可留空）
# DATA_DIR=
# UPLOAD_DIR=
# STATIC_DIR=

# AI 模式: agnes | mock | ollama | api
AI_MODE="agnes"

# --- Agnes AI（文案生成，有免费额度）---
# 注册: https://platform.agnes-ai.com/
# Settings → API Keys → Create new secret key
AI_API_KEY=""
AI_BASE_URL="https://apihub.agnes-ai.com/v1"
AI_MODEL="agnes-2.0-flash"

# --- 兜底：Agnes 不可用时自动切 DeepSeek（默认开启）---
# AI_FALLBACK_MODE="api"   # off 可关闭；也可用逗号链，如 api,ollama
# DeepSeek Key（与 Agnes 分开配置）
AI_FALLBACK_API_KEY=""
# AI_FALLBACK_BASE_URL="https://api.deepseek.com/v1"
# AI_FALLBACK_MODEL="deepseek-chat"
# 也可用别名：DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL

# --- mock 演示模式（不用 Key）---
# AI_MODE="mock"
# AI_API_KEY=""

# --- Ollama 本地免费 ---
# AI_MODE="ollama"
# AI_API_KEY="ollama"
# AI_BASE_URL="http://localhost:11434/v1"
# AI_MODEL="qwen2.5:3b"

# --- DeepSeek 作主模型 ---
# AI_MODE="api"
# AI_API_KEY=""
# AI_BASE_URL="https://api.deepseek.com/v1"
# AI_MODEL="deepseek-chat"

# --- 合规 / 投诉 ---
COMPLAINT_EMAIL="legal@your-domain.com"
OPERATOR_NAME="你的公司全称"
ADMIN_TOKEN="long-random-admin-secret-at-least-16"
# COMPLAINT_SLA_DAYS=15
# RECORD_RETENTION_DAYS=180
# STRICT_SECURITY=1   # 生产且设为 1 时：缺 COMPLAINT_EMAIL/ADMIN_TOKEN 则拒绝启动

# --- 安全 / 配额（P0）---
# 生产环境 JWT_SECRET 必填且 ≥32 位随机串（禁止 change-me-in-production）
# ENABLE_DEMO_PAY=0   # 生产默认关演示支付；本地非 production 默认开。内测可 ENABLE_DEMO_PAY=1
# DAILY_GENERATE_LIMIT=10
# GENERATE_SUBMIT_COOLDOWN_MS=5000
# RATE_LIMIT_AUTH_PER_MIN=20
# RATE_LIMIT_GENERATE_PER_MIN=20
# RATE_LIMIT_IMAGES_PER_MIN=30

# --- P1：CORS / 自动留存 ---
# CORS_ORIGINS=https://your-domain.com   # 逗号分隔；未设时回退 PUBLIC_BASE_URL
# 生产若两者皆空，跨域请求将被拒绝（fail-closed）
# AUTO_PURGE=1                           # 启动后清理超期记录+配图；设 0 关闭
# AUTO_PURGE_INTERVAL_MS=86400000        # 定时间隔，默认 24h

# --- P0：/uploads 签名访问 ---
# 生产默认要求 ?e=&s= 签名；API 出站会自动签名
# UPLOADS_PUBLIC=1           # 强制公开（不推荐）
# UPLOADS_REQUIRE_SIGN=1     # 本地也强制签名
# UPLOAD_SIGN_TTL_SEC=604800 # 默认 7 天
# UPLOAD_SIGN_AGNES_TTL_SEC=7200

# --- 运行日志（仅白名单手机号可查）---
# LOG_VIEWER_PHONE=17682160819
# TASK_LOG_RETENTION_DAYS=7
