DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
PORT=3001

# 公网可达的后端根地址，供 Agnes 拉参考图；本地可留空走临时图床
PUBLIC_BASE_URL=

# AI 模式: agnes | mock | ollama | api
AI_MODE="agnes"

# --- Agnes AI（文案生成，有免费额度）---
# 注册: https://platform.agnes-ai.com/
# Settings → API Keys → Create new secret key
AI_API_KEY=""
AI_BASE_URL="https://apihub.agnes-ai.com/v1"
AI_MODEL="agnes-2.0-flash"

