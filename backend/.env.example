DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
PORT=3001

# 公网可达的后端根地址，供 Agnes 拉参考图；本地可留空走临时图床
PUBLIC_BASE_URL=

# AI 模式: agnes | mock | ollama | api
AI_MODE="agnes"

# --- Agnes AI（文案生成，有免费额度）---
# 注册: https://platform.agnes-ai.com/
# Settings → API Keys → Create new secret key
AI_API_KEY=""
AI_BASE_URL="https://apihub.agnes-ai.com/v1"
AI_MODEL="agnes-2.0-flash"

# --- 兜底：Agnes 不可用时自动切 DeepSeek（默认开启）---
# AI_FALLBACK_MODE="api"   # off 可关闭；也可用逗号链，如 api,ollama
# DeepSeek Key（与 Agnes 分开配置）
AI_FALLBACK_API_KEY=""
# AI_FALLBACK_BASE_URL="https://api.deepseek.com/v1"
# AI_FALLBACK_MODEL="deepseek-chat"
# 也可用别名：DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL

# --- mock 演示模式（不用 Key）---
# AI_MODE="mock"
# AI_API_KEY=""

# --- Ollama 本地免费 ---
# AI_MODE="ollama"
# AI_API_KEY="ollama"
# AI_BASE_URL="http://localhost:11434/v1"
# AI_MODEL="qwen2.5:3b"

# --- DeepSeek 作主模型 ---
# AI_MODE="api"
# AI_API_KEY=""
# AI_BASE_URL="https://api.deepseek.com/v1"
# AI_MODEL="deepseek-chat"
