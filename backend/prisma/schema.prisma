generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  phone          String   @unique
  passwordHash   String
  nickName       String   @default("用户")
  avatar         String   @default("")
  memberPlan     String   @default("none")
  memberExpireAt DateTime?
  isAgent        Boolean  @default(false)
  agentRate      Float    @default(0)
  inviteCode     String?  @unique
  invitedBy      String?
  termsAcceptedAt DateTime?
  ageConfirmedAt  DateTime?
  createdAt      DateTime @default(now())
  records        GenerationRecord[]
  orders         MembershipOrder[]
  commissions    AgentCommission[] @relation("AgentCommissions")
  activationCodes ActivationCode[] @relation("AgentCodes")
  activationRedeems ActivationRedeem[] @relation("UserRedeems")
}

model MembershipOrder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  planId    String
  planName  String
  amount    Float
  status    String   @default("pending")
  paidAt    DateTime?
  createdAt DateTime @default(now())
}

model AgentCommission {
  id          String   @id @default(cuid())
  agentId     String
  agent       User     @relation("AgentCommissions", fields: [agentId], references: [id])
  fromUserId  String
  orderId     String
  orderAmount Float
  rate        Float
  amount      Float
  status      String   @default("settled")
  createdAt   DateTime @default(now())
}

/** 代理卖码：运营发给代理，用户兑换开通；按码记账 */
model ActivationCode {
  id        String   @id @default(cuid())
  code      String   @unique
  agentId   String?
  agent     User?    @relation("AgentCodes", fields: [agentId], references: [id])
  planId    String   @default("trial")
  days      Int      @default(3)
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  note      String   @default("")
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  redeems   ActivationRedeem[]

  @@index([agentId, createdAt])
}

model ActivationRedeem {
  id        String   @id @default(cuid())
  codeId    String
  codeRef   ActivationCode @relation(fields: [codeId], references: [id])
  code      String
  agentId   String?
  userId    String
  user      User     @relation("UserRedeems", fields: [userId], references: [id])
  days      Int
  planId    String   @default("")
  phoneMask String   @default("")
  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@index([code])
}

model TemplateCategory {
  id        String     @id @default(cuid())
  name      String
  sort      Int        @default(0)
  templates Template[]
}

model Template {
  id          String           @id @default(cuid())
  categoryId  String
  category    TemplateCategory @relation(fields: [categoryId], references: [id])
  name        String
  description String
  icon        String           @default("📝")
  prompt      String
  fields      String           @default("[]")
  sort        Int              @default(0)
  records     GenerationRecord[]
}

model GenerationRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  parentId   String?
  parent     GenerationRecord?  @relation("TaskChildren", fields: [parentId], references: [id])
  children   GenerationRecord[] @relation("TaskChildren")
  taskType   String   @default("text")
  status     String   @default("pending")
  input      String
  output     String   @default("")
  imageUrl   String?
  imageUrls  String?
  imageMeta  String?
  imageSize  String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Complaint {
  id          String    @id @default(cuid())
  recordId    String
  contact     String
  reason      String
  evidenceUrl String?
  status      String    @default("pending")
  note        String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String?
  level     String
  message   String
  meta      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([taskId, createdAt])
}
